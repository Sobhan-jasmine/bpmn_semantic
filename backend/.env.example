# API Configuration
DEBUG=false
HOST=0.0.0.0
PORT=8000

# LLM Provider
LLM_PROVIDER_URL=https://api.avalai.ir/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.3

# MariaDB
MARIADB_HOST=localhost
MARIADB_PORT=3306
MARIADB_USER=root
MARIADB_PASSWORD=your_password_here
MARIADB_DATABASE=bpmn_agent

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# Services
SVG_SERVICE_URL=http://localhost:8001/render
SELECTION_BOX_SERVICE_URL=http://localhost:8002/selection
